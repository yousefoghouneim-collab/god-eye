# ──────────────────────────────────────────────────────────────
# GOD-EYE — Environment Variables
# Copy to .env and fill in keys as needed.
# The app runs with ZERO keys (keyless layers only).
# Each key lights up additional layers.
# ──────────────────────────────────────────────────────────────

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Aviation / ADS-B ──
# OPENSKY_USERNAME=           # OpenSky Network (free account)
# OPENSKY_PASSWORD=
# WINGBITS_API_KEY=           # https://wingbits.com
# AVIATIONSTACK_API_KEY=      # https://aviationstack.com
# AIRFRAMES_API_KEY=          # https://airframes.io

# ── Maritime / AIS ──
# AISSTREAM_API_KEY=          # https://aisstream.io
# AISHUB_USERNAME=            # https://aishub.net
# GFW_API_KEY=                # https://globalfishingwatch.org

# ── Satellites / Space ──
# N2YO_API_KEY=               # https://www.n2yo.com

# ── Fire / Climate ──
# NASA_FIRMS_API_KEY=         # https://firms.modaps.eosdis.nasa.gov (free)
# OPENWEATHER_API_KEY=        # https://openweathermap.org

# ── Conflict / Geopolitics ──
# ACLED_API_KEY=              # https://acleddata.com
# ACLED_EMAIL=

# ── Cyber / Threat ──
# SHODAN_API_KEY=             # https://shodan.io
# CLOUDFLARE_RADAR_TOKEN=     # https://radar.cloudflare.com
# OTX_API_KEY=                # https://otx.alienvault.com

# ── Markets / Finance ──
# FINNHUB_API_KEY=            # https://finnhub.io
# FRED_API_KEY=               # https://fred.stlouisfed.org (free)
# UNUSUAL_WHALES_API_KEY=     # https://unusualwhales.com

# ── Imagery / SAR ──
# SENTINEL_HUB_CLIENT_ID=    # https://www.sentinel-hub.com
# SENTINEL_HUB_CLIENT_SECRET=
# EARTHDATA_TOKEN=            # NASA Earthdata bearer token — enables SAR Mode B (free)
#                             # Sign up: https://urs.earthdata.nasa.gov/
# COPERNICUS_TOKEN=           # Copernicus CDSE token — Sentinel Hub optical/SAR (free)
#                             # Sign up: https://dataspace.copernicus.eu/

# ── AI (default: Ollama on localhost, no key) ──
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# GROQ_API_KEY=               # https://groq.com
# OPENROUTER_API_KEY=         # https://openrouter.ai
# ANTHROPIC_API_KEY=          # https://console.anthropic.com

# ── Agent Bus (opt-in, default off) ──
# AGENT_SECRET=               # HMAC secret for Agent Bus — enables POST /api/agent/command
#                             # Generate with: openssl rand -hex 32
# WATCH_OFFICER_ENABLED=true  # Enable AI watch-officer periodic scan
# WATCH_OFFICER_INTERVAL_MS=300000  # Scan interval (default 5min)
# WATCH_OFFICER_MIN_SEVERITY=high   # Minimum severity to alert (low/medium/high/critical)
# WATCH_OFFICER_AI=true       # Use AI for watch-officer briefs (requires AI provider)

# ── Cesium (optional photoreal 3D) ──
# CESIUM_ION_TOKEN=           # https://cesium.com/ion
# GOOGLE_MAPS_API_KEY=        # For Photorealistic 3D Tiles
